# ============================================================
# HMeeting Production Environment Variables
# Copy this file to .env.production and fill in real values
# ============================================================

# Google OAuth (get from console.cloud.google.com)
GOOGLE_CLIENT_ID=your-google-client-id
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# NextAuth (generate with: openssl rand -base64 32)
NEXTAUTH_SECRET=generate-with-openssl-rand-base64-32

# Your production URL (use http://YOUR_LINODE_IP:3000 if no domain)
APP_URL=http://YOUR_LINODE_IP:3000
NEXTAUTH_URL=http://YOUR_LINODE_IP:3000

# Resend email API key (get from resend.com)
RESEND_API_KEY=re_your_resend_api_key

# --- Field-level encryption (choose one) ---

# Option A (recommended): AWS Secrets Manager — key never touches the VM
# 1. Create a secret:  aws secretsmanager create-secret --name hmmeeting/encryption-key --secret-string "$(openssl rand -base64 32)" --region us-east-1
# 2. Attach an IAM role to the EC2 instance with secretsmanager:GetSecretValue permission
# 3. Set these two vars:
AWS_SECRET_NAME=hmmeeting/encryption-key
AWS_REGION=us-east-1

# Option B: Direct key (only for local dev — NOT for production)
# ENCRYPTION_KEY=generate-with-openssl-rand-base64-32

# Database (this is set automatically by docker-compose, but listed for reference)
# DATABASE_URL=file:/app/data/prod.db
