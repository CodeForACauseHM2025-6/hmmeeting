# ============================================================
# HMeeting Production Environment Variables
# Copy this file to .env.production and fill in real values
# ============================================================

# Google OAuth (get from console.cloud.google.com)
GOOGLE_CLIENT_ID=your-google-client-id
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# NextAuth (generate with: openssl rand -base64 32)
AUTH_SECRET=generate-with-openssl-rand-base64-32

# Your production URL — MUST be https://. The app refuses to boot otherwise.
APP_URL=https://your.domain
AUTH_URL=https://your.domain
AUTH_TRUST_HOST=true

# Set to "true" so the rate limiter trusts X-Forwarded-For from nginx.
# Only enable this when nginx (on loopback) is the only thing forwarding
# to the Node process — otherwise clients can spoof the source IP.
TRUST_PROXY=true

# Resend email API key (get from resend.com)
RESEND_API_KEY=re_your_resend_api_key

# --- Field-level encryption (choose one) ---

# Option A (recommended): AWS Secrets Manager — key never touches the VM
# 1. Create a secret:  aws secretsmanager create-secret --name hmmeeting/encryption-key --secret-string "$(openssl rand -base64 32)" --region us-east-1
# 2. Attach an IAM role to the EC2 instance with secretsmanager:GetSecretValue permission
# 3. Set these two vars:
AWS_SECRET_NAME=hmmeeting/encryption-key
AWS_REGION=us-east-1

# Option B: Direct key (only for local dev — NOT for production)
# ENCRYPTION_KEY=generate-with-openssl-rand-base64-32

# --- Backup encryption (separate key from field-level encryption) ---
#
# Backups are AES-256-GCM encrypted under a key kept in a SEPARATE secret
# from the field-level encryption key, so a compromise of one doesn't
# automatically unlock the other.
#
# Option A (recommended): AWS Secrets Manager
# 1. aws secretsmanager create-secret --name hmmeeting/backup-key \
#      --secret-string "$(openssl rand -base64 32)" --region us-east-1
# 2. Same EC2 IAM role needs secretsmanager:GetSecretValue on this ARN too
AWS_BACKUP_SECRET_NAME=hmmeeting/backup-key

# Option B: Direct key (dev only)
# BACKUP_KEY=generate-with-openssl-rand-base64-32

# Database (this is set automatically by docker-compose, but listed for reference)
# DATABASE_URL=file:/app/data/prod.db
