// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
// output   = "../generated/prisma"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id       String @id @default(cuid())
  email    String @unique
  fullName String
  role     Role   @default(STUDENT)

  // If a teacher: 
  teacher Teacher?

  // Appointments where this user is the student
  studentAppointments Appointment[] @relation("StudentAppointments")

  // Student availability (free periods)
  studentAvailability StudentAvailability[]
}

model Teacher {
  id     String  @id @default(cuid())
  userId String  @unique
  user   User    @relation(fields: [userId], references: [id])
  room   String?

  // All appointments where this teacher is the teacher
  appointments Appointment[] @relation("TeacherAppointments")

  availability Availability[]
}

model Appointment {
  id        String            @id @default(cuid())
  day       Int
  period    Period
  status    AppointmentStatus @default(PENDING)
  completedBy CompletionActor?
  room      String?
  studentNote String?
  teacherNote String?
  studentCancelled Boolean @default(false)
  studentAcknowledgedAt DateTime?
  teacherAcknowledgedAt DateTime?
  emailToken    String?  @unique
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  teacher   Teacher  @relation("TeacherAppointments", fields: [teacherId], references: [id])
  teacherId String

  student   User     @relation("StudentAppointments", fields: [studentId], references: [id])
  studentId String
}

model Availability {
  id        String  @id @default(cuid())
  teacher   Teacher @relation(fields: [teacherId], references: [id])
  teacherId String

  day       Int
  period    Period
  type      String  @default("FREE")

  recurring Boolean @default(true)

  @@index([teacherId, day])
  @@unique([teacherId, day, period])
}

model StudentAvailability {
  id     String @id @default(cuid())
  user   User   @relation(fields: [userId], references: [id])
  userId String

  day    Int
  period Period

  @@index([userId, day])
  @@unique([userId, day, period])
}

model AppSettings {
  id          String       @id @default("global")
  currentWeek ScheduleWeek @default(WEEK1)
  weekSetAt   DateTime     @default(now())
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

enum Role {
  STUDENT
  TEACHER
  ADMIN
}

enum Period {
  A
  B
  BREAK
  C
  D
  E
  F
  G
  H
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  DECLINED
  CANCELLED
  COMPLETED
}

enum CompletionActor {
  STUDENT
  TEACHER
}

enum ScheduleWeek {
  WEEK1
  WEEK2
}