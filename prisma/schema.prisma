// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
// output   = "../generated/prisma"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id       String @id @default(cuid())
  email    String @unique
  fullName String
  role     Role   @default(STUDENT)

  // If a teacher: 
  teacher Teacher?

  // Appointments where this user is the student
  studentAppointments Appointment[] @relation("StudentAppointments")
}

model Teacher {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id])

  // All appointments where this teacher is the teacher
  appointments Appointment[] @relation("TeacherAppointments")

  availability Availability[]
}

model Appointment {
  id        String   @id @default(cuid())
  startTime DateTime
  endTime   DateTime

  teacher   Teacher  @relation("TeacherAppointments", fields: [teacherId], references: [id])
  teacherId String

  student   User     @relation("StudentAppointments", fields: [studentId], references: [id])
  studentId String
}

model Availability {
  id        String  @id @default(cuid())
  teacher   Teacher @relation(fields: [teacherId], references: [id])
  teacherId String

  day       Int    
  startTime String  
  endTime   String

  recurring Boolean @default(true)
}

enum Role {
  STUDENT
  TEACHER
  ADMIN
}